# ============================================================
#  FitZone — Environment Variables Example
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ============================================================


# ==================== FLASK CORE ====================

# Secret key used to sign sessions and CSRF tokens.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-in-production


# ==================== DATABASE ====================

# Use 'sqlite' for local development (no setup required).
# Use 'mysql' for staging / production.
DB_TYPE=sqlite

# Only required when DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=fitzone_user
DB_PASSWORD=your_mysql_password_here
DB_NAME=fitzone_db


# ==================== AI / GEMINI ====================

# Google Gemini API key — optional.
# Leave empty to run in mock-AI mode (all features still work offline).
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ==================== FLASK ENVIRONMENT ====================

# Set to 'production' before deploying publicly.
# 'development' enables debug mode and auto-reloader.
FLASK_ENV=development
FLASK_DEBUG=1


# ==================== FILE UPLOADS ====================

# Max upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# Folder where member profile images are stored
UPLOAD_FOLDER=static/uploads


# ==================== SESSION & COOKIES ====================

# How long a "remember me" session lasts (in days)
SESSION_LIFETIME_DAYS=7

# Set to True in production (requires HTTPS)
SESSION_COOKIE_SECURE=False


# ==================== PRODUCTION ONLY ====================

# Uncomment and configure these when deploying to a live server.

# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SERVER_NAME=yourdomain.com

# Email settings for sending payment reminders
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password

# Stripe payments (future integration)
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
